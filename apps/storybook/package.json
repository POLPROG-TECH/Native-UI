{
  "name": "@polprog/storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Design system documentation portal for @polprog/native-ui",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "storybook build -o storybook-static",
    "build-storybook": "storybook build -o storybook-static",
    "bundle-size": "node scripts/check-bundle-size.mjs",
    "serve": "npx serve storybook-static -p 6006",
    "test-runner": "test-storybook",
    "test-runner:ci": "concurrently -k -s first -n SB,TESTS \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "chromatic": "npx chromatic --project-token=${CHROMATIC_PROJECT_TOKEN}"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-links": "^10.5.0",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.5.0",
    "@storybook/test-runner": "^0.24.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-playwright": "^2.0.3",
    "chromatic": "^17.5.0",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "msw": "^2.15.0",
    "msw-storybook-addon": "^2.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native-web": "^0.21.2",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@polprog/native-ui": "*"
  }
}
